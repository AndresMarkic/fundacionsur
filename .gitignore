# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...pero el ejemplo (sin secretos) SÍ se commitea.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite (dev)
dev.db
dev.db-journal

# env (explicito; ya cubierto por .env* mas arriba)
.env
.env*.local

# uploads de usuarios (mantener carpeta, ignorar contenido)
public/uploads/*
!public/uploads/.gitkeep

/src/generated/prisma
